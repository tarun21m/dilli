{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["company", "skill", "date", "summary", "findings", "sources"],
  "properties": {
    "company": { "type": "string" },
    "skill": { "const": "03_value_architecture" },
    "date": { "type": "string" },
    "summary": { "type": "string" },
    "findings": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "target_operating_model": { "type": "string" },
    "margin_profile": { "type": "string" },
    "sources": { "type": "array", "minItems": 1 }
  },
  "additionalProperties": true
}
